{
	"name": "sandbox",
	"description": "Sandbox Strapi 5 + Nuxt 4",
	"author": "Taras Vitruk",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"build": "nuxt build",
		"dev": "nuxt dev",
		"start": "node .output/server/index.mjs",
		"generate": "nuxt generate",
		"preview": "nuxt preview",
		"postinstall": "nuxt prepare",
		"lint:js": "eslint --max-warnings 0 --ignore-pattern public --ignore-pattern eslint-config --ignore-pattern stylelint-config --ignore-pattern '*.config.*' .",
		"lint:css": "stylelint --max-warnings 0 --ignore-path .gitignore **/*.{css,vue}",
		"lint": "npm run lint:js && npm run lint:css",
		"lint:fix": "npm run lint:js -- --fix && npm run lint:css --fix",
		"lint:quiet": "npm run lint:js -- --quiet && npm run lint:css -- --quiet",
		"typecheck": "nuxt typecheck"
	},
	"devDependencies": {
		"@nuxtjs/tailwindcss": "^6.14.0",
		"@stylistic/eslint-plugin": "^5.2.2",
		"@stylistic/stylelint-plugin": "^4.0.0",
		"@types/node": "^24.8.1",
		"@vueuse/core": "^13.6.0",
		"@vueuse/nuxt": "^13.6.0",
		"eslint": "^9.32.0",
		"eslint-config-flat-gitignore": "^2.1.0",
		"eslint-plugin-tailwindcss": "^3.18.2",
		"eslint-plugin-unicorn": "^60.0.0",
		"eslint-plugin-vue": "^10.3.0",
		"nuxt": "^4.1.3",
		"nuxt-strapi-blocks-renderer": "^1.1.2",
		"nuxt-svgo": "^4.2.5",
		"postcss-html": "^1.8.0",
		"stylelint": "^16.23.0",
		"stylelint-order": "^7.0.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.38.0",
		"vite-plugin-checker": "^0.10.1",
		"vue-eslint-parser": "^10.2.0",
		"vue-tsc": "^3.0.4"
	},
	"dependencies": {
		"@nuxtjs/i18n": "^10.0.3",
		"@nuxtjs/sitemap": "^7.4.7",
		"radash": "^12.1.1",
		"valibot": "^1.1.0"
	},
	"engines": {
		"node": "^22",
		"npm": "^10"
	},
	"overrides": {
		"vue": "latest"
	}
}
